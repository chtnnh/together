# Database
# Local: postgresql://postgres:postgres@localhost:5432/together
# Supabase migrations: Session pooler, port 5432 (db.*.supabase.co is IPv6-only)
# Supabase / Vercel runtime: Transaction pooler, port 6543 ?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/together

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube (set in repo root .env — loaded automatically by apps/web/next.config.ts)
YOUTUBE_API_KEY=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Apple Music
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Realtime
NEXT_PUBLIC_REALTIME_URL=ws://localhost:8787
ROOM_TOKEN_SECRET=change-me-in-production

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production example:
# NEXT_PUBLIC_APP_URL=https://together.chtnnhfoundation.org
# NEXT_PUBLIC_REALTIME_URL=wss://realtime.together.chtnnhfoundation.org
