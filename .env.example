# Copy to repo root `.env` (loaded by apps/web/next.config.ts and local scripts).

# Database
# Local: postgresql://postgres:postgres@localhost:5432/together
# Supabase migrations: Session pooler, port 5432 (db.*.supabase.co is IPv6-only)
# Supabase / Vercel runtime: Transaction pooler, port 6543 ?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/together

# Supabase (required for magic-link sign-in; set both public vars)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API (search, track resolve)
YOUTUBE_API_KEY=

# Spotify OAuth + import (redirect URI: {NEXT_PUBLIC_APP_URL}/auth/callback/spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# SoundCloud resolve/playlists (public API client id)
SOUNDCLOUD_CLIENT_ID=

# Apple Music (optional — out of v0.2.0 scope)
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Realtime worker (must match ROOM_TOKEN_SECRET in services/realtime/wrangler.toml)
NEXT_PUBLIC_REALTIME_URL=ws://127.0.0.1:8787
ROOM_TOKEN_SECRET=dev-secret-change-me

# App origin (invite links, Spotify redirect, etc.)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Optional — Playwright / CI only
# TOGETHER_E2E=1
# TOGETHER_SKIP_ENV_FILE=1

# Production example:
# NEXT_PUBLIC_APP_URL=https://together.example.com
# NEXT_PUBLIC_REALTIME_URL=wss://realtime.together.example.com
