{
  "name": "@together/web",
  "version": "0.3.2",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--require ./scripts/load-root-env.cjs' next dev --turbopack",
    "build": "NODE_OPTIONS='--require ./scripts/load-root-env.cjs' next build",
    "start": "NODE_OPTIONS='--require ./scripts/load-root-env.cjs' next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --project=chromium --project=mobile-chrome",
    "test:visual": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test visual-regression.spec.ts",
    "test:visual:docker": "bash scripts/visual-regression-linux.sh test",
    "test:visual:update": "bash scripts/visual-regression-linux.sh update",
    "test:mobile": "playwright test mobile-room.spec.ts",
    "test:install": "playwright install --with-deps chromium firefox webkit"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.2",
    "@together/db": "workspace:*",
    "@together/shared": "workspace:*",
    "@together/track-resolver": "workspace:*",
    "@together/ui": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "emoji-mart": "^5.6.0",
    "jose": "^6.0.11",
    "lucide-react": "^0.525.0",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3"
  }
}
