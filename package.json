{
  "name": "together",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:realtime": "pnpm --filter @together/realtime run build",
    "deploy:realtime": "pnpm --filter @together/realtime exec wrangler deploy --env production",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @together/db generate",
    "db:migrate": "pnpm --filter @together/db migrate"
  },
  "devDependencies": {
    "turbo": "^2.10.1",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22"
  }
}
